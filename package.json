{
  "name": "discord-trading-signal-collector",
  "version": "1.0.0",
  "description": "7×24 Discord trading signal collector with auto-recovery",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "test": "jest",
    "test:unit": "jest --testPathPattern=unit",
    "test:integration": "jest --testPathPattern=integration",
    "test:e2e": "jest --testPathPattern=e2e --runInBand",
    "test:watch": "jest --watch",
    "coverage": "jest --coverage",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix"
  },
  "dependencies": {
    "discord.js": "^14.0.0",
    "express": "^4.18.0",
    "pg": "^8.8.0",
    "dotenv": "^16.0.0",
    "winston": "^3.8.0",
    "node-cron": "^3.0.0",
    "axios": "^1.3.0"
  },
  "devDependencies": {
    "jest": "^29.0.0",
    "eslint": "^8.0.0",
    "prettier": "^2.8.0",
    "nodemon": "^2.0.0",
    "supertest": "^6.3.0"
  }
}
