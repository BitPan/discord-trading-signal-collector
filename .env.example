# 应用配置
NODE_ENV=production
API_PORT=3000

# 数据库配置（Docker 内部通信）
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/discord_collector

# Discord 配置
DISCORD_USER_TOKEN=your_user_token_here

# Telegram 配置
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# 日志级别
LOG_LEVEL=info
