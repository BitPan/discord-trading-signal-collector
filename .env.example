# Discord
DISCORD_BOT_TOKEN=your_bot_token_here
DISCORD_CHANNELS=channel_id_1,channel_id_2
DISCORD_USERS=user_id_1,user_id_2
DISCORD_LOOKBACK_DAYS=30

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/trading
DATABASE_BACKUP_INTERVAL=3600

# Telegram Alert
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_ALERT_CHAT_ID=your_chat_id

# API
API_PORT=3000
API_AUTH_KEY=your_api_key_here

# Environment
NODE_ENV=development
LOG_LEVEL=info
